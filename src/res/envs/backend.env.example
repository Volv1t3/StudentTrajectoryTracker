# Backend Environment Variables Template
# Copy to backend.env and fill in your values

# MySQL Database
DB_HOST=<backend-db-host>
DB_PORT=<backend-db-port>
DB_NAME=<backend-db-name>
DB_USER=<backend-db-user>
DB_PASSWORD=<backend-db-password>

# JWT Secret (must match frontend)
JWT_ACCESS_SECRET=<jwt-access-secret>
JWT_REFRESH_SECRET=<jwt-refresh-secret>
JWT_ACCESS_EXPIRES_IN=<jwt-access-expires-in>
JWT_REFRESH_EXPIRES_IN=<jwt-refresh-expires-in>
JWT_ADMIN_ACCESS_EXPIRES_IN=<jwt-admin-access-expires-in>
JWT_ADMIN_REFRESH_EXPIRES_IN=<jwt-admin-refresh-expires-in>
BCRYPT_ROUNDS=<bcrypt-rounds>

ACTIVATION_TOKEN_SECRET=<activation-token-secret>
RESET_TOKEN_SECRET=<reset-token-secret>
ACTIVATION_TOKEN_TTL_H=<activation-token-ttl-h>
RESET_TOKEN_TTL_M=<reset-token-ttl-m>

# Server
PORT=<server-port>
NODE_ENV=<node-env>

# Site URL (for CORS / redirects)
SITE_URL=<site-url>


# API Keys and Storage Configuration

RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=<resend-email-from>
EMAIL_FROM_NAME=<resend-email-from-name>
SUPABASE_URL=<supabase-url>
SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
STORAGE_PROVIDER=<storage-provider>
SUPABASE_BUCKET_PROJECTS=<supabase-bucket-projects>
SUPABASE_BUCKET_EVENTS=<supabase-bucket-events>
UPLOAD_MAX_SIZE_MB=<supabase-upload-max-size-mb>
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp
POSTHOG_KEY=<posthog-key>
POSTHOG_HOST=<posthog-host>
