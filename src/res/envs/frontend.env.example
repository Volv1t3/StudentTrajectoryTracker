# Supabase Configuration
SUPABASE_URL=<supabase_url>
SUPABASE_PUBLISHABLE_KEY=<supabase_public_key>

# Resend Email
RESEND_API_KEY=<resend_api_key>

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=<jwt_secret>

# Site Configuration
SITE_URL=<site_url>

# Backend API
API_BASE_URL=<backend_api_url>

# PostHog Analytics (optional)
PUBLIC_POSTHOG_KEY=<posthog_public_key>
PUBLIC_POSTHOG_HOST=<posthog_host>
POSTHOG_ADMIN_DASHBOARD_EMBED_URL=<posthog-admin-dashboard-embed-url>
POSTHOG_ADMIN_DASHBOARD_PUBLIC_URL=<posthog-admin-dashboard-embed-url>

# MySQL Database (used by Docker Compose to connect frontend to database)
DB_HOST=<db_host>
DB_PORT=<db_port>
DB_NAME=<db_name>
DB_USER=<db_user>
DB_PASSWORD=<db_password>
